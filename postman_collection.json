{
  "info": {
    "name": "MLOps Student Score Predictor",
    "description": "Experiment 6: API testing collection for the FastAPI ML service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "api_key", "value": "mlops-demo-key-2024" },
    { "key": "jwt_token", "value": "" }
  ],
  "item": [
    {
      "name": "General",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        },
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/"
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('jwt_token', jsonData.access_token);",
                  "pm.test('Token received', function () {",
                  "    pm.expect(jsonData.access_token).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/token?username=test_user"
          }
        }
      ]
    },
    {
      "name": "Prediction — Auth Testing",
      "item": [
        {
          "name": "Predict with API Key (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has predicted score', function () {",
                  "    pm.expect(pm.response.json().predicted_final_score).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/predict",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hours\": 5,\n  \"attendance\": 70,\n  \"previous_score\": 60\n}"
            }
          }
        },
        {
          "name": "Predict with JWT Token (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has predicted score', function () {",
                  "    pm.expect(pm.response.json().predicted_final_score).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/predict",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{jwt_token}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hours\": 8,\n  \"attendance\": 90,\n  \"previous_score\": 80\n}"
            }
          }
        },
        {
          "name": "Predict WITHOUT Auth (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/predict",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hours\": 5,\n  \"attendance\": 70,\n  \"previous_score\": 60\n}"
            }
          }
        },
        {
          "name": "Predict with INVALID API Key (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/predict",
            "header": [
              { "key": "X-API-Key", "value": "wrong-key-12345" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hours\": 5,\n  \"attendance\": 70,\n  \"previous_score\": 60\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Prediction — Validation & Errors",
      "item": [
        {
          "name": "Invalid: hours < 0 (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', function () { pm.response.to.have.status(422); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/predict",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hours\": -5,\n  \"attendance\": 70,\n  \"previous_score\": 60\n}"
            }
          }
        },
        {
          "name": "Invalid: attendance > 100 (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', function () { pm.response.to.have.status(422); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/predict",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hours\": 5,\n  \"attendance\": 200,\n  \"previous_score\": 60\n}"
            }
          }
        },
        {
          "name": "Invalid: missing field (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', function () { pm.response.to.have.status(422); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/predict",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hours\": 5\n}"
            }
          }
        },
        {
          "name": "Invalid: empty body (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', function () { pm.response.to.have.status(422); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/predict",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "Invalid: wrong data types (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', function () { pm.response.to.have.status(422); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/predict",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hours\": \"abc\",\n  \"attendance\": true,\n  \"previous_score\": null\n}"
            }
          }
        }
      ]
    }
  ]
}
